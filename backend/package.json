{
  "name": "lin",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": " echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "dev": "nodemon ./src/app.ts",
    "start": "cross-env NODE_ENV=production node ./dist/app.js",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "typeorm:cli": "ts-node ./node_modules/typeorm/cli -f ./src/Dbconfig/ormconfig.ts",
    "db:drop": "npm run typeorm:cli schema:drop",
    "migration:generate": "typeorm migration:create -n",
    "db:create": "ts-node src/script/create-db.ts",
    "db:migrate": "cross-env NODE_ENV=development npm run typeorm:cli migration:run",
    "db:revert": "npm run typeorm:cli migration:revert",
    "db:sync": "cross-env NODE_ENV=development npm run typeorm:cli schema:sync && npm run db:migrate" 
  },
  "dependencies": {
        "bcrypt": "^5.0.1",
        "body-parser": "^1.20.0",
        "cors": "^2.8.5",
        "cross-env": "^7.0.3",
        "helmet": "^5.1.1",
        "joi": "^17.6.0",
        "jsonwebtoken": "^8.5.1",
        "multer": "^1.4.5-lts.1",
        "mysql": "^2.18.1",
        "mysql2": "^2.3.3",
        "nanoid": "^4.0.0",
        "nodemailer": "^6.7.5",
        "nodemon": "^2.0.19",
        "passport": "^0.6.0",
        "passport-jwt": "^4.0.0",
        "reflect-metadata": "^0.1.13",
        "swagger-ui-express": "^4.4.0",
        "ts-node": "^10.9.1",
        "typeorm": "^0.2.32",
        "underscore": "^1.13.4",
        "uuid": "^8.3.2"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/cors": "^2.8.12",
        "@types/helmet": "^4.0.0",
        "@types/jsonwebtoken": "^8.5.8",
        "@types/multer": "^1.4.7",
        "@types/node": "^18.0.0",
        "@types/nodemailer": "^6.4.4",
        "@types/passport-jwt": "^3.0.6",
        "@types/swagger-ui-express": "^4.1.3",
        "@types/underscore": "^1.11.4",
        "@types/uuid": "^8.3.4"
    }
}
