{
  "name": "lin",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": " echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "dev": "nodemon ./src/app.ts",
    "start": "cross-env NODE_ENV=production node ./dist/app.js",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "typeorm:cli": "ts-node ./node_modules/typeorm/cli -f ./src/Dbconfig/ormconfig.ts",
    "db:drop": "npm run typeorm:cli schema:drop",
    "migration:generate": "typeorm migration:create -n",
    "db:create": "ts-node src/script/create-db.ts",
    "db:migrate": "cross-env NODE_ENV=development npm run typeorm:cli migration:run",
    "db:revert": "npm run typeorm:cli migration:revert",
    "db:sync": "cross-env NODE_ENV=development npm run typeorm:cli schema:sync " 
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.0.1",
    "dotenv": "^16.0.1",
    "ejs": "^3.1.8",
    "express": "^4.18.1",
    "express-flash": "^0.0.2",
    "express-session": "^1.17.3",
    "method-override": "^3.0.0",
    "nodemon": "^2.0.19",
    "passport": "^0.6.0",
    "passport-local": "^1.0.0"
  }
}
